# Django
DJANGO_SETTINGS_MODULE=root.settings.production
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# Database
DATABASE_URL=postgres://db_user:db_password@db-host:5432/app_db

# HTTP / CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://frontend.example.com
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://frontend.example.com

# JWT cookies
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800
JWT_AUTH_COOKIE=jwt
JWT_REFRESH_COOKIE=refresh_token
JWT_ALLOW_COOKIE_AUTH=True
JWT_ENFORCE_CSRF=True
JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=Lax

# GraphQL production switches
RAIL_ENABLE_PROD_GRAPHIQL=False
RAIL_ENABLE_PROD_INTROSPECTION=False
RAIL_METADATA_DEPLOY_VERSION_MODE=command
RAIL_METADATA_DEPLOY_VERSION_KEY=default

# ASGI runtime
WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=120

# Cache
CACHE_PATH=./cache

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@example.com

# Webhooks
RAIL_WEBHOOKS_ENABLED=False
RAIL_WEBHOOK_URLS=
RAIL_WEBHOOK_SIGNING_SECRET=



